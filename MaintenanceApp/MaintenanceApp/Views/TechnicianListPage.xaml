<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MaintenanceApp.Views.TechnicianListPage"
             Title="Technicians"
             BackgroundColor="White"
             Shell.BackgroundColor="#3700B3"
             Shell.ForegroundColor="White"
             Shell.TitleColor="White">
    <RefreshView IsRefreshing="{Binding IsBusy}"
                 Refreshing="RefreshView_Refreshing">
        <CollectionView Margin="12"
                        ItemsSource="{Binding Technicians}"
                        EmptyView="No technicians found">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,4"
                           Padding="12"
                           CornerRadius="8"
                           HasShadow="False"
                           BorderColor="#E0E0E0">
                        <VerticalStackLayout Spacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding Name}"
                                       FontAttributes="Bold"
                                       TextColor="#202124" />
                                <Label Grid.Column="1"
                                       Text="{Binding Status}"
                                       TextColor="#3700B3" />
                            </Grid>
                            <Label Text="{Binding EmployeeNo}" TextColor="#666666" />
                            <Label Text="{Binding SkillType, StringFormat='Skill: {0}'}"
                                   FontSize="12"
                                   TextColor="#666666" />
                            <Label Text="{Binding Shift, StringFormat='Shift: {0}'}"
                                   FontSize="12"
                                   TextColor="#666666" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>
</ContentPage>
