<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MaintenanceApp.Views.CmmsDashboardPage"
             Title="Dashboard"
             BackgroundColor="White"
             Shell.BackgroundColor="#3700B3"
             Shell.ForegroundColor="White"
             Shell.TitleColor="White">
    <RefreshView IsRefreshing="{Binding IsBusy}"
                 Refreshing="RefreshView_Refreshing">
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="14">
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#B00020"
                       IsVisible="{Binding HasError}" />

                <CollectionView ItemsSource="{Binding Metrics}">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="4"
                                   Padding="14"
                                   CornerRadius="8"
                                   HasShadow="False"
                                   BorderColor="#E0E0E0">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Title}"
                                           FontSize="12"
                                           TextColor="#666666" />
                                    <Label Text="{Binding Value}"
                                           FontSize="22"
                                           FontAttributes="Bold"
                                           TextColor="#202124" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Top Downtime"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#202124" />
                <CollectionView ItemsSource="{Binding TopDowntimeAssets}"
                                HeightRequest="180"
                                EmptyView="No downtime data">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" ColumnDefinitions="*,Auto">
                                <Label Text="{Binding AssetName}" TextColor="#202124" />
                                <Label Grid.Column="1" Text="{Binding Value, StringFormat='{0} min'}" TextColor="#666666" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Top Failure"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#202124" />
                <CollectionView ItemsSource="{Binding TopFailureAssets}"
                                HeightRequest="180"
                                EmptyView="No failure data">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8" ColumnDefinitions="*,Auto">
                                <Label Text="{Binding AssetName}" TextColor="#202124" />
                                <Label Grid.Column="1" Text="{Binding Value}" TextColor="#666666" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
