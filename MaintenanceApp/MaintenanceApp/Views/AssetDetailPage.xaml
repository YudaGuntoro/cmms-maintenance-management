<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MaintenanceApp.Views.AssetDetailPage"
             Title="Asset Detail"
             BackgroundColor="White"
             Shell.BackgroundColor="#3700B3"
             Shell.ForegroundColor="White"
             Shell.TitleColor="White">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="{Binding ErrorMessage}"
                   TextColor="#B00020"
                   IsVisible="{Binding HasError}" />

            <Label Text="{Binding Asset.AssetCode}"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#202124" />
            <Label Text="{Binding Asset.AssetName}"
                   FontSize="18"
                   TextColor="#202124" />
            <Label Text="{Binding Asset.Status, StringFormat='Status: {0}'}"
                   TextColor="#3700B3" />
            <Label Text="{Binding Asset.CriticalityLevel, StringFormat='Criticality: {0}'}"
                   TextColor="#666666" />
            <Label Text="{Binding Asset.Location, StringFormat='Location: {0}'}"
                   TextColor="#666666" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Frame Padding="12" CornerRadius="8" HasShadow="False" BorderColor="#E0E0E0">
                    <VerticalStackLayout>
                        <Label Text="MTTR" FontSize="12" TextColor="#666666" />
                        <Label Text="{Binding Kpi.MttrMinutes, StringFormat='{0:0.##} min'}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#202124" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="1" Padding="12" CornerRadius="8" HasShadow="False" BorderColor="#E0E0E0">
                    <VerticalStackLayout>
                        <Label Text="MTBF" FontSize="12" TextColor="#666666" />
                        <Label Text="{Binding Kpi.MtbfMinutes, StringFormat='{0:0.##} min'}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#202124" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <Label Text="Work Order History"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="#202124" />
            <CollectionView ItemsSource="{Binding WorkOrders}"
                            HeightRequest="360"
                            EmptyView="No work orders">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                            <Label Text="{Binding WoNumber}" FontAttributes="Bold" TextColor="#202124" />
                            <Label Grid.Column="1" Text="{Binding Status}" TextColor="#3700B3" />
                            <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Title}" TextColor="#666666" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
