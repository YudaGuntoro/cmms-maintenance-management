<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MaintenanceApp.Views.AssetListPage"
             Title="Assets"
             BackgroundColor="White"
             Shell.BackgroundColor="#3700B3"
             Shell.ForegroundColor="White"
             Shell.TitleColor="White">
    <Grid Padding="12" RowDefinitions="Auto,Auto,*" RowSpacing="10">
        <SearchBar Placeholder="Search asset"
                   Text="{Binding SearchText}"
                   SearchButtonPressed="SearchBar_SearchButtonPressed" />

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <Picker ItemsSource="{Binding StatusOptions}"
                    SelectedItem="{Binding StatusFilter}" />
            <Button Grid.Column="1"
                    Text="Filter"
                    BackgroundColor="#3700B3"
                    TextColor="White"
                    Clicked="Filter_Clicked" />
        </Grid>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Assets}"
                        SelectionMode="Single"
                        SelectionChanged="Assets_SelectionChanged"
                        EmptyView="No assets found">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,4"
                           Padding="12"
                           CornerRadius="8"
                           HasShadow="False"
                           BorderColor="#E0E0E0">
                        <VerticalStackLayout Spacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding AssetCode}"
                                       FontAttributes="Bold"
                                       TextColor="#202124" />
                                <Label Grid.Column="1"
                                       Text="{Binding Status}"
                                       TextColor="#3700B3" />
                            </Grid>
                            <Label Text="{Binding AssetName}"
                                   TextColor="#202124" />
                            <Label Text="{Binding ProductionLine}"
                                   FontSize="12"
                                   TextColor="#666666" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
