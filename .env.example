# Copy this file to .env on the VPS, then fill production values there.
# Never commit .env.

FRONTEND_ORIGIN=https://cmms.nusakaryadigital.com
NEXT_PUBLIC_API_BASE_URL=https://cmms.nusakaryadigital.com

# aaPanel should proxy the domain to this one Docker gateway port.
WEB_HOST_PORT=8088

# If MySQL is installed directly on the same VPS, keep Server=host.docker.internal.
# Create a dedicated MySQL user for production; do not use root.
MYSQL_CONNECTION_STRING=Server=host.docker.internal;Port=3306;User ID=maintenance_user;Password=change-me;Database=db_maintenance;SslMode=None;AllowPublicKeyRetrieval=True;

JWT_ISSUER=MaintenanceApp
JWT_AUDIENCE=MaintenanceApp.Frontend
JWT_SIGNING_KEY=replace-with-a-long-random-production-secret
JWT_EXPIRES_HOURS=8

# Keep false for public production unless you intentionally need Swagger UI.
SWAGGER_ENABLED=false
